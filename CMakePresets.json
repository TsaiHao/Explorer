{
    "version": 3,
    "configurePresets": [
        {
            "name": "android-arm7-debug",
            "displayName": "Android ARM7 Debug Build",
            "description": "Build for Android ARM7 architecture in debug mode",
            "binaryDir": "${sourceDir}/debug",
            "generator": "Ninja",
            "toolchainFile": "$env{ANDROID_NDK_ROOT}/build/cmake/android.toolchain.cmake",
            "cacheVariables": {
                "CMAKE_CXX_STANDARD": "17",
                "ANDROID_ABI": "armeabi-v7a",
                "ANDROID_PLATFORM": "android-31",
                "ENABLE_DEBUG": "ON",
                "TARGET_ANDROID": "ON"
            }
        },
        {
            "name": "android-arm7-release",
            "displayName": "Android ARM7 release Build",
            "description": "Build for Android ARM7 architecture in release mode",
            "binaryDir": "${sourceDir}/release",
            "generator": "Ninja",
            "toolchainFile": "$env{ANDROID_NDK_ROOT}/build/cmake/android.toolchain.cmake",
            "cacheVariables": {
                "CMAKE_CXX_STANDARD": "17",
                "CMAKE_BUILD_TYPE": "Release",
                "ANDROID_ABI": "armeabi-v7a",
                "ANDROID_PLATFORM": "android-31",
                "ENABLE_DEBUG": "OFF",
                "TARGET_ANDROID": "ON"
            }
        },
        {
            "name": "vega-debug",
            "displayName": "Linux armhf Debug Build",
            "description": "Build for Linux armhf (GLIBC) using system toolchain",
            "binaryDir": "${sourceDir}/vega_debug",
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_BUILD_WITH_INSTALL_RPATH": "ON",
                "CMAKE_SYSTEM_NAME": "Linux",
                "CMAKE_SYSTEM_PROCESSOR": "arm",
                "CMAKE_C_COMPILER": "arm-linux-gnueabihf-gcc",
                "CMAKE_CXX_COMPILER": "arm-linux-gnueabihf-g++",
                "CMAKE_CXX_STANDARD": "17",
                "TARGET_ANDROID": "OFF",
                "TARGET_VEGA": "ON",
                "ENABLE_DEBUG": "ON",
                "STATIC_LIBSTDCPP": "ON"
            },
            "environment": {
                "CXXFLAGS": "-march=armv7-a -mfloat-abi=hard -mfpu=neon" 
            }
        }
    ]
}
